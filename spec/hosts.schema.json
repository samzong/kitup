{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kitup.dev/schemas/hosts.schema.json",
  "title": "kitup host adapter specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "hosts"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "hosts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/host"
      }
    }
  },
  "$defs": {
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "projectSkillsDirs",
        "userSkillsDirs",
        "detect",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "uniqueItems": true
        },
        "projectSkillsDirs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projectPath"
          },
          "uniqueItems": true
        },
        "userSkillsDirs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/homePath"
          },
          "uniqueItems": true
        },
        "detect": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/detectPath"
          },
          "uniqueItems": true
        },
        "status": {
          "enum": [
            "verified",
            "documented",
            "community",
            "experimental"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "anyOf": [
        {
          "properties": {
            "projectSkillsDirs": {
              "minItems": 1
            }
          }
        },
        {
          "properties": {
            "userSkillsDirs": {
              "minItems": 1
            }
          }
        }
      ]
    },
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!~)(?!.*(^|/)\\.\\.(/|$))[^\\u0000]+$"
    },
    "homePath": {
      "type": "string",
      "minLength": 3,
      "pattern": "^~/[^\\u0000]+$"
    },
    "detectPath": {
      "anyOf": [
        {
          "$ref": "#/$defs/homePath"
        },
        {
          "$ref": "#/$defs/projectPath"
        }
      ]
    }
  }
}
