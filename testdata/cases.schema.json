{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kitup.dev/schemas/cases.schema.json",
  "title": "kitup golden case file",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "cases"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "operation",
        "description",
        "options",
        "given",
        "expected"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "operation": {
          "enum": [
            "detect",
            "install",
            "plan",
            "resolve-hosts",
            "update",
            "uninstall",
            "validate"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "type": "object",
          "additionalProperties": true
        },
        "given": {
          "type": "object",
          "additionalProperties": true
        },
        "expected": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
