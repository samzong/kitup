    {
      "id": "changed-update",
      "operation": "update",
      "description": "Replaces a kitup-owned target when its metadata hash differs from the bundled skill.",
      "options": {
        "appId": "example-cli",
        "skillDir": "testdata/skills/basic",
        "scope": "user",
